{
	"name": "blp-preview-pro",
	"displayName": "BLP Preview Pro - Warcraft III Assets Viewer",
	"description": "Professional Warcraft III asset viewer with BLP/TGA image preview, MPQ archive explorer, W3X map visualization, 3D model display, and format conversion tools. Enhanced edition with advanced file browsing and resource extraction capabilities.",
	"version": "1.1.0",
	"publisher": "eiriksgata",
	"license": "MIT",
	"icon": "icon.png",
	"engines": {
		"vscode": "^1.58.0",
		"node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/eiriksgata/vscode-plugin-blp-preview-pro.git"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCustomEditor:blpPreviewPro.previewEditor",
		"onCustomEditor:blpPreviewPro.previewEditor.forMpq",
		"onView:blpPreviewPro.mpqExplorer",
		"onView:blpPreviewPro.w3xExplorer",
		"onCommand:blpPreviewPro.selectMpqLocation",
		"onCommand:blpPreviewPro.reloadMpqArchives",
		"onCommand:blpPreviewPro.showMpqStatus",
		"onCommand:blpPreviewPro.openMpq",
		"onCommand:blpPreviewPro.openW3X",
		"onCommand:blpPreviewPro.exploreW3XFile",
		"onCommand:blpPreviewPro.extractAll",
		"onCommand:blpPreviewPro.convert2png",
		"onCommand:blpPreviewPro.convert2jpg",
		"onCommand:blpPreviewPro.convert2blp",
		"onCommand:blpPreviewPro.convert2mdl",
		"onCommand:blpPreviewPro.convert2mdx"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "blpPreviewProMpqExplorer",
					"title": "MPQ Explorer",
					"icon": "media/resource/mpq.svg"
				}
			]
		},
		"views": {
			"explorer": [
				{
					"id": "blpPreviewPro.w3xExplorer",
					"name": "W3X Explorer"
				}
			],
			"blpPreviewProMpqExplorer": [
				{
					"id": "blpPreviewPro.mpqExplorer",
					"name": "MPQ Explorer",
					"icon": "media/resource/mpq.svg",
					"contextualTitle": "blpPreviewPro"
				}
			]
		},
		"customEditors": [
			{
				"viewType": "blpPreviewPro.previewEditor",
				"displayName": "blp-preview",
				"priority": "default",
				"selector": [
					{
						"filenamePattern": "*.{blp,tga,mdx,w3e,slk,mmp,w3c}"
					}
				]
			},
			{
				"viewType": "blpPreviewPro.previewEditor.forMpq",
				"displayName": "blp-preview for mqp",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.{blp,tga,mdx,w3e,slk,mmp,w3c}"
					}
				]
			}
		],
		"commands": [
			{
				"command": "blpPreviewPro.selectMpqLocation",
				"title": "Select Warcraft MPQ Path",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.reloadMpqArchives",
				"title": "Reload MPQ Archives",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.showMpqStatus",
				"title": "Show MPQ Status",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.openMpq",
				"title": "Open MPQ Resource",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.openW3X",
				"title": "Open W3X Resource",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.extractAll",
				"title": "%blpPreviewPro.extractAll%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.exploreW3XFile",
				"title": "%blpPreviewPro.exploreW3XFile%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.w3xExplorerClear",
				"title": "%blpPreviewPro.w3xExplorerClear%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.extractFile",
				"title": "%blpPreviewPro.extractFile%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.extractFileWithTexture",
				"title": "%blpPreviewPro.extractFileWithTexture%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.copyModel",
				"title": "%blpPreviewPro.copyModel%",
				"category": "Blp Resource"
			},
			{
				"command": "blpPreviewPro.copyFile",
				"title": "%blpPreviewPro.copyFile%",
				"category": "Blp Resource"
			},
			{
				"command": "blpPreviewPro.convert2png",
				"title": "%blpPreviewPro.convert2png%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.convert2jpg",
				"title": "%blpPreviewPro.convert2jpg%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.convert2blp",
				"title": "%blpPreviewPro.convert2blp%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.convert2mdl",
				"title": "%blpPreviewPro.convert2mdl%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.convert2mdx",
				"title": "%blpPreviewPro.convert2mdx%",
				"category": "Blp Preview"
			},
			{
				"command": "blpPreviewPro.copyPath",
				"title": "%blpPreviewPro.copyPath%",
				"category": "Blp Preview"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "blpPreviewPro.selectMpqLocation",
					"when": "view == blpPreviewPro.mpqExplorer"
				},
				{
					"command": "blpPreviewPro.reloadMpqArchives",
					"when": "view == blpPreviewPro.mpqExplorer"
				},
				{
					"command": "blpPreviewPro.showMpqStatus",
					"when": "view == blpPreviewPro.mpqExplorer"
				},
				{
					"command": "blpPreviewPro.w3xExplorerClear",
					"when": "view == blpPreviewPro.w3xExplorer"
				}
			],
			"editor/title/context": [
				{
					"command": "blpPreviewPro.exploreW3XFile",
					"when": "resourceExtname == .w3x || resourceExtname == .w3m || resourceExtname == .mpq"
				},
				{
					"command": "blpPreviewPro.extractAll",
					"when": "resourceExtname == .w3x || resourceExtname == .w3m || resourceExtname == .mpq"
				}
			],
			"view/item/context": [
				{
					"command": "blpPreviewPro.copyPath",
					"when": "view == blpPreviewPro.mpqExplorer && viewItem =~ /file$/i"
				},
				{
					"command": "blpPreviewPro.extractFile",
					"when": "view == blpPreviewPro.w3xExplorer && viewItem =~ /file$/i"
				},
				{
					"command": "blpPreviewPro.extractFileWithTexture",
					"when": "view == blpPreviewPro.w3xExplorer && viewItem == mdxFile"
				},
				{
					"command": "blpPreviewPro.copyModel",
					"when": "view == blpPreviewPro.w3xExplorer && viewItem == mdxFile"
				},
				{
					"command": "blpPreviewPro.copyFile",
					"when": "view == blpPreviewPro.w3xExplorer && viewItem =~ /file$/i"
				},
				{
					"command": "blpPreviewPro.extractAll",
					"when": "view == blpPreviewPro.w3xExplorer && viewItem == w3x"
				}
			],
			"explorer/context": [
				{
					"command": "blpPreviewPro.exploreW3XFile",
					"when": "resourceExtname == .w3x || resourceExtname == .w3m || resourceExtname == .mpq"
				},
				{
					"command": "blpPreviewPro.extractAll",
					"when": "resourceExtname == .w3x || resourceExtname == .w3m || resourceExtname == .mpq"
				},
				{
					"when": "resourceExtname == .blp",
					"command": "blpPreviewPro.convert2png"
				},
				{
					"when": "resourceExtname == .blp",
					"command": "blpPreviewPro.convert2jpg"
				},
				{
					"when": "resourceExtname == .png || resourceExtname == .jpg || resourceExtname == .jpeg",
					"command": "blpPreviewPro.convert2blp"
				},
				{
					"when": "resourceExtname == .mdx",
					"command": "blpPreviewPro.convert2mdl"
				},
				{
					"when": "resourceExtname == .mdl",
					"command": "blpPreviewPro.convert2mdx"
				}
			]
		},
		"configuration": {
			"type": "object",
			"title": "blpPreviewPro configuration",
			"properties": {
				"blpPreviewPro.mpqLocation": {
					"type": "string",
					"default": "",
					"description": "%blpPreviewPro.mpqLocation.desc%"
				},
				"blpPreviewPro.retainContextWhenHidden": {
					"type": "boolean",
					"default": false,
					"description": "%blpPreviewPro.retainContextWhenHidden.desc%"
				},
				"blpPreviewPro.convert2blp": {
					"type": "boolean",
					"default": false,
					"description": "%blpPreviewPro.convert2blp.desc%"
				},
				"blpPreviewPro.convert2mdl": {
					"type": "boolean",
					"default": false,
					"description": "%blpPreviewPro.convert2mdl.desc%"
				},
				"blpPreviewPro.convert2mdx": {
					"type": "boolean",
					"default": false,
					"description": "%blpPreviewPro.convert2mdx.desc%"
				},
				"blpPreviewPro.convert2jpg": {
					"type": "boolean",
					"default": false,
					"description": "%blpPreviewPro.convert2jpg.desc%"
				},
				"blpPreviewPro.convert2png": {
					"type": "boolean",
					"default": false,
					"description": "%blpPreviewPro.convert2png.desc%"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"test-compile": "tsc -p ./",
		"test-watch": "tsc -watch -p ./",
		"pretest": "npm run test-compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@babel/core": "^7.14.6",
		"@babel/preset-typescript": "^7.14.5",
		"@types/glob": "^7.1.3",
		"@types/mocha": "^8.2.2",
		"@types/node": "^22.0.0",
		"@types/vscode": "^1.58.0",
		"@typescript-eslint/eslint-plugin": "^4.26.0",
		"@typescript-eslint/parser": "^4.26.0",
		"babel-loader": "^8.2.2",
		"css-loader": "^6.7.3",
		"eslint": "^7.27.0",
		"file-loader": "^6.2.0",
		"gl-matrix": "^3.3.0",
		"glob": "^7.1.7",
		"less-loader": "^11.1.0",
		"mdx-m3-viewer": "^5.12.0",
		"mini-css-extract-plugin": "^2.7.5",
		"mocha": "^10.2.0",
		"raw-loader": "^4.0.2",
		"ts-loader": "^9.2.2",
		"typescript": "^4.3.2",
		"vscode-test": "^1.5.2",
		"war3-model": "^2.2.1",
		"webpack": "^5.38.1",
		"webpack-cli": "^4.7.0"
	},
	"dependencies": {
		"temp-dir": "^1.0.0",
		"fs-extra": "^11.1.1",
		"pako": "^2.0.4",
		"vscode-nls": "^5.2.0"
	},
	"babel": {
		"presets": [
			"@babel/preset-typescript"
		]
	}
}
